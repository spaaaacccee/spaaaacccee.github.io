---
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  philosophy: CollectionEntry<"homepage">["data"]["philosophy"];
};

const { philosophy } = Astro.props;
---

<section class="section" id="about">
  <div class="container">
    <div class="flex justify-center text-center">
      <div class="max-w-2xl">
        <p
          class="text-2xl md:text-3xl lg:text-4xl font-primary text-text-light/90 mb-10 leading-snug text-balance"
          set:html={markdownify(philosophy.opening)}
          data-aos="fade-up-sm"
        />
        <p
          class="text-lg md:text-xl text-text leading-relaxed mb-8 font-secondary text-balance"
          set:html={markdownify(philosophy.body)}
          data-aos="fade-up-sm"
          data-aos-delay="50"
        />
        <p
          class="text-lg md:text-xl text-text-light font-medium font-secondary"
          set:html={markdownify(philosophy.closer)}
          data-aos="fade-up-sm"
          data-aos-delay="100"
        />
      </div>
    </div>
  </div>
</section>
