---
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  pillars: CollectionEntry<"homepage">["data"]["pillars"];
};

const { pillars } = Astro.props;
---

<section class="section pt-0">
  <div class="container">
    <div class="flex justify-center">
      <div class="w-full max-w-5xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 rounded-xl overflow-hidden border border-accent/40">
          {
            pillars.map((pillar: any, index: number) => (
              <div
                class:list={[
                  "py-10 md:py-12 md:px-8 px-8 lg:px-12 bg-primary/70",
                  index < pillars.length - 1 && "border-b md:border-b-0 md:border-r border-border/50",
                ]}
                data-aos="fade-up-sm"
                data-aos-delay={index * 100}
              >
                <h3
                  set:html={markdownify(pillar.keyword)}
                  class="text-2xl md:text-3xl font-primary text-text-light mb-4"
                />
                <p
                  set:html={markdownify(pillar.description)}
                  class="text-text leading-relaxed font-secondary"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
