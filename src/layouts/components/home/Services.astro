---
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  services: CollectionEntry<"homepage">["data"]["services"];
};

const { services } = Astro.props;
---

<section class="section" id="services">
  <div class="container">
    <div class="flex justify-center mb-16">
      <h2
        set:html={markdownify(services.headline)}
        class="text-3xl md:text-4xl lg:text-5xl font-primary text-text-light text-center max-w-xl text-balance"
        data-aos="fade-up-sm"
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {
        services.items.map((item: any, index: number) => (
          <div
            class="py-8 md:py-0"
            data-aos="fade-up-sm"
            data-aos-delay={index * 100}
          >
            <h3
              set:html={markdownify(item.title)}
              class="text-xl lg:text-2xl font-primary text-text-light mb-4"
            />
            <p
              set:html={markdownify(item.description)}
              class="text-text leading-relaxed lg:text-base"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
