---
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  hero: CollectionEntry<"homepage">["data"]["hero"];
};

const { hero } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden" id="hero">
  <!-- Kaleidoscope background -->
  <!-- <div class="kaleidoscope-bg" aria-hidden="true">
    <div class="kaleidoscope-layer kaleidoscope-layer-1"></div>
    <div class="kaleidoscope-layer kaleidoscope-layer-2"></div>
    <div class="kaleidoscope-layer kaleidoscope-layer-3"></div>
  </div> -->

  <div class="container relative z-10">
    <div class="flex flex-col items-center justify-center text-center">
      <h1
        set:html={markdownify(hero.tagline)}
        class="text-6xl md:text-6xl lg:text-6xl xl:text-8xl font-primary font-normal text-text-light mb-6 tracking-tight"
        data-aos="fade-up-sm"
      />
      <p
        set:html={markdownify(hero.subtitle)}
        class="text-lg md:text-xl text-text font-secondary tracking-tight"
        data-aos="fade-up-sm"
        data-aos-delay="100"
      />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10"
    data-aos-delay="300"
  >
    <div class="w-px h-12 bg-linear-to-b from-transparent to-text-light/30 mx-auto mb-2"></div>
    <span class="text-xs text-text/50 font-secondary uppercase tracking-widest">Scroll</span>
  </div>
</section>
