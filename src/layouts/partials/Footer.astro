---
import config from "@/config/config.json";
import { markdownify } from "@/lib/utils/textConverter";

const { copyright } = config.params;
---

<footer class="py-12 border-t border-border/50">
  <div class="container">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div >
        <a href="/" class="flex items-center gap-2">
          <span class="text-lg font-primary text-text-light tracking-tight">Kaleidoscope MT</span>
        </a>
      </div>
      <p
        class="text-sm text-text/60"
        set:html={markdownify(copyright)}
        
      />
      <a
        href="mailto:enquiry@kmt.global"
        class="text-sm text-text hover:text-secondary transition"
        
      >
        enquiry@kmt.global
      </a>
    </div>
  </div>
</footer>
